container_commands:
    01_installnode:
        command: |
            curl -sL https://rpm.nodesource.com/setup_16.x | sudo bash -
            yum install -y nodejs
    02_npminstall:
        command: "source $PYTHONPATH/activate && npm install"
    03_npmbuild:
        command: "source $PYTHONPATH/activate && npm run build"
    04_collectstatic:
        command: "source $PYTHONPATH/activate && python manage.py collectstatic --noinput"
    05_migrate:
        command: "source $PYTHONPATH/activate && python manage.py migrate --noinput"

option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: crew_rates.wsgi:application